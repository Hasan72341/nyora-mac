GOOGLE_DESKTOP_CLIENT_ID=181067068545-5r2ob1jv4mc0v8gd52fgk2jt28pk3370.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID=181067068545-4jkfesn716ucqbuhcbtvdtlqfg3ar38u.apps.googleusercontent.com

